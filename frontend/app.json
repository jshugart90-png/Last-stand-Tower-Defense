{
  "expo": {
    "name": "Last Stand Tower Defense",
    "slug": "last-stand-tower-defense",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "laststandtd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.horseshoeroundme.laststandtowerdefense",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.INTERNET"
      ],
      "package": "com.horseshoeroundme.laststandtowerdefense"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "dynamic"
          }
        }
      ],
      "expo-iap",
      "expo-web-browser"
    ],
    "extra": {
      "EXPO_PUBLIC_BACKEND_URL": "",
      "router": {},
      "eas": {
        "projectId": "7b990481-5fbc-492f-905e-6e0c24a31bf7"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
